extends ../../layouts/default.pug
include ../../mixins/filter-status.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
include ../../mixins/bulk-change-status.pug
include ../../mixins/sort.pug

block main
  h1 Trang danh sách sản phẩm
  if selectedCategory
    .alert.alert-info
      | Đang lọc theo danh mục:
      strong.ml-1 #{selectedCategory.title}
      a.btn.btn-sm.btn-outline-secondary.ml-3(href=`${prefixAdmin}/products`) Xóa lọc

  .card.mb-3
    .card-header Bộ lọc và Tìm kiếm
    .card-body
      .row
        .col-lg-4.col-md-12.mb-2
          +filter-status(filterStatus)
        .col-lg-8.col-md-12.d-flex.justify-content-between.flex-wrap
          +search(keyword)
          +sort(sort)
          a.btn.btn-primary.ml-2(href=`${prefixAdmin}/products/create`) Thêm mới sản phẩm

  .card.mb-3
    .card-header Danh Sách
    .card-body

      // Bulk change form
      +bulkChangeStatus(`${prefixAdmin}/products/change-multi?_method=PATCH`)

      table.table.table-bordered
        thead
          tr
            th
              input(type="checkbox" id="check-all")
            th STT
            th Hình ảnh
            th Tiêu đề
            th Danh mục
            th Giá
            th Vị trí
            th Trạng thái
            th Hành động
        tbody
          each item, index in products
            tr
              td
                input(type="checkbox" name="id" value=item._id class="check-item")
              td #{pagination.skip + index + 1}
              td
                a(href=`${prefixAdmin}/products/detail/${item._id}`)
                  img(src=item.thumbnail alt=item.title width="100px")
              td 
                a(href=`${prefixAdmin}/products/detail/${item._id}`) #{item.title}
              td #{item.categoryTitle || "—"}
              td #{item.price}$
              td #{item.position !== undefined && item.position !== null && item.position !== "" ? item.position : "—"}
              td
                if item.status == "active"
                  a.badge.badge-success(
                    href="javascript:;"
                    data-status=item.status
                    data-id=item._id
                    button-change-status
                  ) Hoạt động
                else
                  a.badge.badge-danger(
                    href="javascript:;"
                    data-status=item.status
                    data-id=item._id
                    button-change-status
                  ) Dừng Hoạt động
              td
                a.btn.btn-warning.btn-sm(href=`${prefixAdmin}/products/edit/${item._id}`) Sửa
                button.btn.btn-danger.btn-sm.ml-1(
                  data-id=item._id
                  button-delete
                ) Xóa

  +pagination(pagination, status, keyword, sort)

  // Form ẩn change status 1 sản phẩm
  form(
    action=""
    method="POST"
    id="form-change-status"
    data-path=`${prefixAdmin}/products/change-status`
  )

  // Form ẩn xóa sản phẩm 
  form(
    action=""
    method="POST"
    id="form-delete-item"
    data-path=`${prefixAdmin}/products/delete`
  )
block scripts
  script(src="/admin/js/product.js")
