extends ../../layouts/default.pug
include ../../mixins/filter-status.pug
include ../../mixins/search.pug

block main
  h1 Trang danh sách sản phẩm

  .card.mb-3
    .card-header Bộ lọc và Tìm kiếm
    .card-body
      .row
        .col-6
          +filter-status(filterStatus)
        .col-6
          +search(keyword)

  .card.mb-3
    .card-header Danh Sách
    .card-body
      table.table.table-bordered
        thead
          tr
            th STT
            th Hình ảnh
            th Tiêu đề
            th Giá
            th Trạng thái
            th Hành động
        tbody
          each item, index in products
            tr
              td #{index}
              td
                img(src=item.thumbnail alt=item.title width="100px")
              td #{item.title}
              td #{item.price}$
              td
                if (item.status == "active")
                  a.badge.badge-success Hoạt động
                else
                  a.badge.badge-danger Dừng Hoạt động
              td
                button.btn.btn-warning.btn-sm Sửa
                button.btn.btn-danger.btn-sm.ml-1 Xóa

  // Pagination (PHẢI ở trong block main)
  if pagination && pagination.totalPage > 1
    - const currentPage = pagination.currentPage
    - const totalPage = pagination.totalPage
    - const prevPage = currentPage - 1
    - const nextPage = currentPage + 1

    // giữ query (status, keyword)
    - const queryObj = {}
    - if (status) queryObj.status = status
    - if (keyword) queryObj.keyword = keyword

    nav
      ul.pagination
        // Trang trước
        li.page-item(class=(currentPage <= 1 ? "disabled" : ""))
          - queryObj.page = prevPage
          a.page-link(
            href=(currentPage <= 1 ? "javascript:void(0)" : ("?" + (new URLSearchParams(queryObj)).toString()))
          ) Trang trước

        // Các trang
        - for (let p = 1; p <= totalPage; p++)
          li.page-item(class=(p === currentPage ? "active" : ""))
            - queryObj.page = p
            a.page-link(href=("?" + (new URLSearchParams(queryObj)).toString())) #{p}

        // Kế tiếp
        li.page-item(class=(currentPage >= totalPage ? "disabled" : ""))
          - queryObj.page = nextPage
          a.page-link(
            href=(currentPage >= totalPage ? "javascript:void(0)" : ("?" + (new URLSearchParams(queryObj)).toString()))
          ) Kế tiếp